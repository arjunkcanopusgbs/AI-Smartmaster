<mvc:View
    controllerName="LoginApp.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">
    <Page title="Login" class="sapUiContentPadding">
        <content>
            <VBox alignItems="Center" justifyContent="Center" class="sapUiSmallMarginTop">
                <Input
                    id="usernameInput"
                    placeholder="Username"
                    width="40%"
                    class="sapUiSmallMarginBottom" />
                <Input
                    id="passwordInput"
                    placeholder="Password"
                    type="Password"
                    width="40%"
                    class="sapUiSmallMarginBottom" />
                <Button
                    text="Login"
                    press="onLoginPress"
                    width="40%"
                    type="Emphasized" />
            </VBox>
        </content>
    </Page>
</mvc:View>